-- FUNÇÃO CRIAR BOTÃO TOGGLE FUNCIONAL
local function CreateToggle(name, icon, yPos, getState, setState, onToggle)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(1, 0, 0, 42)
    Btn.Position = UDim2.new(0, 0, 0, yPos)
    Btn.BackgroundColor3 = getState() and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
    Btn.Text = icon .. " " .. name .. (getState() and "  ON" or "  OFF")
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 14
    Btn.Font = Enum.Font.GothamBold
    Btn.Parent = ButtonContainer
    
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 10)
    
    local Stroke = Instance.new("UIStroke", Btn)
    Stroke.Color = getState() and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(100, 100, 100)
    Stroke.Thickness = 2
    
    -- FUNÇÃO ATUALIZAR VISUAL
    local function UpdateVisual()
        local state = getState()
        Btn.BackgroundColor3 = state and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
        Btn.Text = icon .. " " .. name .. (state and "  ON" or "  OFF")
        Stroke.Color = state and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(100, 100, 100)
    end
    
    -- CLICK HANDLER CORRIGIDO
    Btn.Activated:Connect(function()
        setState(not getState())
        UpdateVisual()
        
        if onToggle then
            onToggle(getState())
        end
        
        print("[" .. name .. "] " .. (getState() and "ATIVADO" or "DESATIVADO"))
    end)
    
    return Btn, UpdateVisual
end

