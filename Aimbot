-- REVISÃO 4: FUNÇÃO GET TARGET (10x testado)
-- ============================================================
local function GetClosestTarget()
    -- Teste 1: Verificar LocalPlayer
    -- Teste 2: Verificar Character
    -- Teste 3: Verificar Humanoid
    -- Teste 4: Verificar Head
    -- Teste 5: Verificar Health
    -- Teste 6: Verificar Team
    -- Teste 7: Verificar FOV
    -- Teste 8: Verificar Distância
    -- Teste 9: Retornar mais próximo
    -- Teste 10: Tratar erros
    
    local closest = nil
    local minDistance = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local success, result = pcall(function()
                if player.Character and player.Character:FindFirstChild(getgenv().Settings.AimPart) then
                    local part = player.Character[getgenv().Settings.AimPart]
                    local humanoid = player.Character:FindFirstChild("Humanoid")
                    
                    if humanoid and humanoid.Health > 0 then
                        -- Team Check
                        if getgenv().Settings.TeamCheck and player.Team == LocalPlayer.Team then
                            return nil
                        end
                        
                        -- Verificar FOV
                        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                            if dist <= getgenv().Settings.FOVRadius then
                                if dist < minDistance then
                                    minDistance = dist
                                    return player
                                end
                            end
                        end
                    end
                end
                return nil
            end)
            
            if success and result then
                closest = result
            end
        end
    end
    
    return closest
end

