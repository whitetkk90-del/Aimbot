-- REVISÃO 5: AIMBOT (10x testado)
-- ============================================================
local function ExecuteAimbot()
    -- Teste 1: Verificar se ativado
    -- Teste 2: Limpar alvo se desativado
    -- Teste 3: Verificar LocalPlayer
    -- Teste 4: Verificar Character
    -- Teste 5: Pegar alvo
    -- Teste 6: Verificar alvo válido
    -- Teste 7: Pegar parte do corpo
    -- Teste 8: Calcular predição
    -- Teste 9: Aplicar suavização
    -- Teste 10: Atualizar câmera
    
    if not getgenv().Settings.Aimbot then
        getgenv().CurrentTarget = nil
        return
    end
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    local target = GetClosestTarget()
    getgenv().CurrentTarget = target
    
    if target and target.Character then
        local part = target.Character:FindFirstChild(getgenv().Settings.AimPart)
        if part then
            local prediction = part.Position + (part.Velocity * 0.15)
            local targetCFrame = CFrame.new(Camera.CFrame.Position, prediction)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 - getgenv().Settings.Smoothness)
        end
    end
end

