local function GetClosestPlayer()
    local closest = nil
    local minDistance = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local targetPart = character:FindFirstChild(AimPart)
            
            if humanoid and humanoid.Health > 0 and targetPart then
                -- Team Check
                if TeamCheckEnabled and player.Team == LocalPlayer.Team then
                    continue
                end
                
                -- Verificar se está na tela
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local distanceFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    
                    -- Verificar se está dentro do FOV
                    if distanceFromCenter <= FOVRadius then
                        local distanceFromPlayer = (targetPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                        
                        if distanceFromCenter < minDistance then
                            minDistance = distanceFromCenter
                            closest = player
                        end
                    end
                end
            end
        end
    end
    
    return closest
end

local function RunAimbot()
    if not AimbotEnabled then
        CurrentTarget = nil
        return
    end
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    CurrentTarget = GetClosestPlayer()
    
    if CurrentTarget and CurrentTarget.Character then
        local targetPart = CurrentTarget.Character:FindFirstChild(AimPart)
        if targetPart then
            -- Predição de movimento
            local velocity = targetPart.Velocity
            local predictedPosition = targetPart.Position + (velocity * 0.165)
            
            -- Criar CFrame mirando para o alvo
            local targetCFrame = CFrame.new(Camera.CFrame.Position, predictedPosition)
            
            -- Aplicar suavização
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 - Smoothness)
        end
    end
end

local function RunESP()
    -- Esconder tudo primeiro
    for _, e in pairs(ESPObjects) do
        if e.Box then e.Box.Visible = false end
        if e.Tracer then e.Tracer.Visible = false end
        if e.Name then e.Name.Visible = false end
    end
    
    if not ESPEnabled then return end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    local localHRP = LocalPlayer.Character.HumanoidRootPart
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and hrp and humanoid.Health > 0 then
                -- Team Check
                if TeamCheckEnabled and player.Team == LocalPlayer.Team then
                    continue
                end
                
                -- Verificar distância
                local distance = (hrp.Position - localHRP.Position).Magnitude
                if distance > 2000 then continue end
                
                -- Verificar se está na tela
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    -- Criar objetos se não existirem
                    if not ESPObjects[player] then
                        ESPObjects[player] = {
                            Box = Drawing.new("Square"),
                            Tracer = Drawing.new("Line"),
                            Name = Drawing.new("Text")
                        }
                        ESPObjects[player].Box.Thickness = 2
                        ESPObjects[player].Box.Filled = false
                        ESPObjects[player].Name.Size = 14
                        ESPObjects[player].Name.Center = true
                        ESPObjects[player].Name.Outline = true
                        ESPObjects[player].Name.OutlineColor = Color3.new(0, 0, 0)
                    end
                    
                    local e = ESPObjects[player]
                    
                    -- Calcular tamanho do box
                    local headPos = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                    local footPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                    local boxHeight = math.abs(headPos.Y - footPos.Y)
                    local boxWidth = boxHeight * 0.6
                    
                    -- Cor baseada no time
                    local isEnemy = not (TeamCheckEnabled and player.Team == LocalPlayer.Team)
                    local color = isEnemy and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(0, 255, 100)
                    
                    -- Atualizar Box
                    e.Box.Size = Vector2.new(boxWidth, boxHeight)
                    e.Box.Position = Vector2.new(pos.X - boxWidth / 2, pos.Y - boxHeight / 2)
                    e.Box.Color = color
                    e.Box.Visible = true
                    
                    -- Atualizar Tracer
                    e.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    e.Tracer.To = Vector2.new(pos.X, pos.Y + boxHeight / 2)
                    e.Tracer.Color = color
                    e.Tracer.Thickness = 1.5
                    e.Tracer.Visible = true
                    
                    -- Atualizar Nome
                    e.Name.Text = player.Name .. " [" .. math.floor(humanoid.Health) .. "HP]"
                    e.Name.Position = Vector2.new(pos.X, pos.Y - boxHeight / 2 - 20)
                    e.Name.Color = Color3.new(1, 1, 1)
                    e.Name.Visible = true
                end
            end
        end
    end
end

