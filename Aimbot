-- FUNÇÃO: PEGAR ALVO NO FOV
local function GetTarget()
    local closest = nil
    local minDist = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local part = player.Character:FindFirstChild(_G.AimPart)
            
            if humanoid and humanoid.Health > 0 and part then
                if _G.TeamCheck and player.Team == LocalPlayer.Team then continue end
                
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distFromCenter = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                    if distFromCenter < _G.FOVRadius and distFromCenter < minDist then
                        minDist = distFromCenter
                        closest = player
                    end
                end
            end
        end
    end
    
    return closest
end

-- FUNÇÃO: AIMBOT
local function RunAimbot()
    if not _G.Aimbot then
        _G.Target = nil
        return
    end
    
    _G.Target = GetTarget()
    
    if _G.Target and _G.Target.Character then
        local targetPart = _G.Target.Character[_G.AimPart]
        if targetPart and LocalPlayer.Character then
            local predictedPos = targetPart.Position + (targetPart.Velocity * 0.165)
            local targetCFrame = CFrame.new(Camera.CFrame.Position, predictedPos)
            
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 - _G.Smoothness)
        end
    end
end

-- FUNÇÃO: ESP
local function RunESP()
    -- LIMPAR VISIBILIDADE
    for _, e in pairs(ESPObjects) do
        if e.Box then e.Box.Visible = false end
        if e.Tracer then e.Tracer.Visible = false end
        if e.Name then e.Name.Visible = false end
    end
    
    if not _G.ESP then return end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local humanoid = char:FindFirstChild("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            
            if humanoid and hrp and humanoid.Health > 0 then
                if _G.TeamCheck and player.Team == LocalPlayer.Team then continue end
                
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    -- CRIAR SE NÃO EXISTE
                    if not ESPObjects[player] then
                        ESPObjects[player] = {
                            Box = Drawing.new("Square"),
                            Tracer = Drawing.new("Line"),
                            Name = Drawing.new("Text")
                        }
                        ESPObjects[player].Box.Thickness = 2
                        ESPObjects[player].Box.Filled = false
                        ESPObjects[player].Name.Size = 13
                        ESPObjects[player].Name.Center = true
                        ESPObjects[player].Name.Outline = true
                        ESPObjects[player].Name.OutlineColor = Color3.new(0, 0, 0)
                    end
                    
                    local e = ESPObjects[player]
                    local boxHeight = math.abs(Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0)).Y)
                    local boxWidth = boxHeight * 0.6
                    
                    -- COR (VERDE = TIME, VERMELHO = INIMIGO)
                    local color = (_G.TeamCheck and player.Team == LocalPlayer.Team) and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
                    
                    -- BOX
                    e.Box.Size = Vector2.new(boxWidth, boxHeight)
                    e.Box.Position = Vector2.new(pos.X - boxWidth / 2, pos.Y - boxHeight / 2)
                    e.Box.Color = color
                    e.Box.Visible = true
                    
                    -- TRACER
                    e.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    e.Tracer.To = Vector2.new(pos.X, pos.Y + boxHeight / 2)
                    e.Tracer.Color = color
                    e.Tracer.Thickness = 1.5
                    e.Tracer.Visible = true
                    
                    -- NOME + HP
                    e.Name.Text = player.Name .. " [" .. math.floor(humanoid.Health) .. "HP]"
                    e.Name.Position = Vector2.new(pos.X, pos.Y - boxHeight / 2 - 15)
                    e.Name.Color = Color3.new(1, 1, 1)
                    e.Name.Visible = true
                end
            end
        end
    end
end

