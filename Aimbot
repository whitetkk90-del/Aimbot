-- FUNÇÃO: PEGAR ALVO
local function GetTarget()
    local closest = nil
    local minDist = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local targetPart = player.Character:FindFirstChild(AimPart)
            
            if humanoid and humanoid.Health > 0 and targetPart then
                if TeamCheckEnabled and player.Team == LocalPlayer.Team then
                    continue
                end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    if dist <= FOVRadius and dist < minDist then
                        minDist = dist
                        closest = player
                    end
                end
            end
        end
    end
    
    return closest
end

-- FUNÇÃO: AIMBOT
local function RunAimbot()
    if not AimbotEnabled then
        CurrentTarget = nil
        return
    end
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    CurrentTarget = GetTarget()
    
    if CurrentTarget and CurrentTarget.Character then
        local targetPart = CurrentTarget.Character:FindFirstChild(AimPart)
        if targetPart then
            local predictedPos = targetPart.Position + (targetPart.Velocity * 0.165)
            local targetCFrame = CFrame.new(Camera.CFrame.Position, predictedPos)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 - Smoothness)
        end
    end
end

-- FUNÇÃO: ESP
local function RunESP()
    -- Esconder tudo
    for _, obj in pairs(ESPObjects) do
        if obj.Box then obj.Box.Visible = false end
        if obj.Tracer then obj.Tracer.Visible = false end
        if obj.Name then obj.Name.Visible = false end
    end
    
    if not ESPEnabled then return end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    local localHRP = LocalPlayer.Character.HumanoidRootPart
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and hrp and humanoid.Health > 0 then
                if TeamCheckEnabled and player.Team == LocalPlayer.Team then
                    continue
                end
                
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    if not ESPObjects[player] then
                        ESPObjects[player] = {
                            Box = Drawing.new("Square"),
                            Tracer = Drawing.new("Line"),
                            Name = Drawing.new("Text")
                        }
                        ESPObjects[player].Box.Thickness = 2
                        ESPObjects[player].Box.Filled = false
                        ESPObjects[player].Name.Size = 14
                        ESPObjects[player].Name.Center = true
                        ESPObjects[player].Name.Outline = true
                    end
                    
                    local obj = ESPObjects[player]
                    local headPos = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                    local footPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                    local boxHeight = math.abs(headPos.Y - footPos.Y)
                    local boxWidth = boxHeight * 0.6
                    
                    obj.Box.Size = Vector2.new(boxWidth, boxHeight)
                    obj.Box.Position = Vector2.new(pos.X - boxWidth / 2, pos.Y - boxHeight / 2)
                    obj.Box.Color = Color3.fromRGB(255, 50, 50)
                    obj.Box.Visible = true
                    
                    obj.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    obj.Tracer.To = Vector2.new(pos.X, pos.Y + boxHeight / 2)
                    obj.Tracer.Color = Color3.fromRGB(255, 50, 50)
                    obj.Tracer.Thickness = 1.5
                    obj.Tracer.Visible = true
                    
                    obj.Name.Text = player.Name .. " [" .. math.floor(humanoid.Health) .. "HP]"
                    obj.Name.Position = Vector2.new(pos.X, pos.Y - boxHeight / 2 - 20)
                    obj.Name.Color = Color3.new(1, 1, 1)
                    obj.Name.Visible = true
                end
            end
        end
    end
end

