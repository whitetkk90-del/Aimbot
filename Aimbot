-- FUNÇÃO CRIAR BOTÃO TOGGLE
local function CreateToggle(name, icon, setting, yPos)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(1, 0, 0, 38)
    Btn.Position = UDim2.new(0, 0, 0, yPos)
    Btn.BackgroundColor3 = _G[setting] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
    Btn.Text = icon .. " " .. name .. (_G[setting] and "  ON" or "  OFF")
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 13
    Btn.Font = Enum.Font.GothamBold
    Btn.Parent = ButtonContainer
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 10)
    BtnCorner.Parent = Btn
    
    -- STROKE/BORDA
    local Stroke = Instance.new("UIStroke")
    Stroke.Color = _G[setting] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(100, 100, 100)
    Stroke.Thickness = 1.5
    Stroke.Parent = Btn
    
    -- INTERAÇÃO
    Btn.MouseButton1Click:Connect(function()
        _G[setting] = not _G[setting]
        
        -- ANIMAÇÃO
        TweenService:Create(Btn, TweenInfo.new(0.2), {
            BackgroundColor3 = _G[setting] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
        }):Play()
        
        TweenService:Create(Stroke, TweenInfo.new(0.2), {
            Color = _G[setting] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(100, 100, 100)
        }):Play()
        
        Btn.Text = icon .. " " .. name .. (_G[setting] and "  ON" or "  OFF")
        
        -- FECHAR ESP SE DESLIGAR
        if setting == "ESP" and not _G[setting] then
            for _, e in pairs(ESPObjects) do
                if e.Box then e.Box.Visible = false end
                if e.Tracer then e.Tracer.Visible = false end
                if e.Name then e.Name.Visible = false end
            end
        end
        
        -- NOTIFICAÇÃO
        if _G[setting] then
            print("✅ " .. name .. " ativado")
        end
    end)
    
    -- HOVER EFFECT
    Btn.MouseEnter:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.15), {
            BackgroundColor3 = _G[setting] and Color3.fromRGB(0, 230, 120) or Color3.fromRGB(80, 80, 90)
        }):Play()
    end)
    
    Btn.MouseLeave:Connect(function()
        TweenService:Create(Btn, TweenInfo.new(0.15), {
            BackgroundColor3 = _G[setting] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
        }):Play()
    end)
    
    return Btn
end

