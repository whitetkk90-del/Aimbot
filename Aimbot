-- REVISÃO 6: ESP (10x testado)
-- ============================================================
local function ExecuteESP()
    -- Teste 1: Esconder tudo primeiro
    -- Teste 2: Verificar se ativado
    -- Teste 3: Verificar LocalPlayer
    -- Teste 4: Loop players
    -- Teste 5: Verificar Character
    -- Teste 6: Verificar Humanoid
    -- Teste 7: Verificar Team
    -- Teste 8: Calcular posição na tela
    -- Teste 9: Criar/atualizar drawings
    -- Teste 10: Aplicar cor e visibilidade
    
    -- Esconder tudo
    for _, data in pairs(getgenv().ESPData) do
        if data.Box then data.Box.Visible = false end
        if data.Tracer then data.Tracer.Visible = false end
        if data.Name then data.Name.Visible = false end
    end
    
    if not getgenv().Settings.ESP then return end
    if not LocalPlayer.Character then return end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local success = pcall(function()
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = player.Character.HumanoidRootPart
                    local humanoid = player.Character:FindFirstChild("Humanoid")
                    
                    if humanoid and humanoid.Health > 0 then
                        -- Team Check
                        if getgenv().Settings.TeamCheck and player.Team == LocalPlayer.Team then
                            return
                        end
                        
                        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                        if onScreen then
                            -- Criar se não existir
                            if not getgenv().ESPData[player] then
                                getgenv().ESPData[player] = {
                                    Box = Drawing.new("Square"),
                                    Tracer = Drawing.new("Line"),
                                    Name = Drawing.new("Text")
                                }
                                getgenv().ESPData[player].Box.Thickness = 2
                                getgenv().ESPData[player].Box.Filled = false
                                getgenv().ESPData[player].Name.Size = 13
                                getgenv().ESPData[player].Name.Center = true
                                getgenv().ESPData[player].Name.Outline = true
                            end
                            
                            local data = getgenv().ESPData[player]
                            local top = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                            local bottom = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                            local height = math.abs(top.Y - bottom.Y)
                            local width = height * 0.6
                            
                            -- Box
                            data.Box.Size = Vector2.new(width, height)
                            data.Box.Position = Vector2.new(pos.X - width/2, pos.Y - height/2)
                            data.Box.Color = Color3.fromRGB(255, 50, 50)
                            data.Box.Visible = true
                            
                            -- Tracer
                            data.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                            data.Tracer.To = Vector2.new(pos.X, bottom.Y)
                            data.Tracer.Color = Color3.fromRGB(255, 50, 50)
                            data.Tracer.Thickness = 1.5
                            data.Tracer.Visible = true
                            
                            -- Name
                            data.Name.Text = player.Name .. " | " .. math.floor(humanoid.Health) .. "HP"
                            data.Name.Position = Vector2.new(pos.X, top.Y - 15)
                            data.Name.Color = Color3.new(1, 1, 1)
                            data.Name.Visible = true
                        end
                    end
                end
            end)
        end
    end
end

